    // -----------------------------------------------------------
    // Depop Required Specifics Injector
    // Selects the FIRST brand option
    // -----------------------------------------------------------

    async function depopInjectRequiredSpecifics(vm){
        console.log("[Vendoo][Depop] Injecting REQUIRED specifics (Brand)…");

        // 1. Locate the Depop brand field container
        const root = document.querySelector('[data-testid="listings.depop.overrides.brand-multi-selector-container"]')
        || document.querySelector('#listings\\.depop\\.overrides\\.brand')
        || document.querySelector('input[name="listings.depop.overrides.brand"]');

        if (!root){
            console.warn("[Depop] Brand container NOT FOUND.");
            return;
        }

        // The actual Downshift <input>
        const input = (
            root.tagName === 'INPUT'
            ? root
            : root.querySelector('input')
        );

        if (!input){
            console.warn("[Depop] Brand input NOT FOUND.");
            return;
        }

        // Step 1: open the dropdown
        input.scrollIntoView({behavior:"smooth", block:"center"});
        await sleep(rand(120,200));
        input.focus();
        await sleep(rand(120,200));

        // Step 2: Type a char to trigger Downshift search
        setNativeValue(input, "a");
        input.dispatchEvent(new InputEvent("input", {bubbles:true}));
        await sleep(rand(140,220));

        // Step 3: ArrowDown to force menu open
        input.dispatchEvent(new KeyboardEvent("keydown", {
            key: "ArrowDown",
            code: "ArrowDown",
            keyCode: 40,
            which: 40,
            bubbles: true
        }));
        await sleep(rand(150,300));

        // Step 4: find the Downshift menu
        const menuId = input.getAttribute("aria-controls");
        let listbox = null;

        for (let i = 0; i < 12; i++){
            listbox = menuId
                ? document.getElementById(menuId)
            : document.querySelector('[role="listbox"]');

            if (listbox && listbox.offsetParent !== null) break;
            await sleep(120);
        }

        if (!listbox){
            console.warn("[Depop] listbox NOT FOUND.");
            return;
        }

        // Step 5: find visible options
        const options = Array.from(listbox.querySelectorAll('[role="option"]'))
        .filter(el => el.offsetParent !== null);

        if (!options.length){
            console.warn("[Depop] No visible brand options.");
            return;
        }

        const first = options[0];

        console.log("[Depop] Selecting FIRST brand option:", first.textContent.trim());
        await safeClick(first);

        await blurCommit(input);

        console.log("[Vendoo][Depop] Brand injection COMPLETE.");
    }

    // -----------------------------------------------------------
    // Poshmark Required Specifics Injector
    // Auto-fills required "Size" with "NA" when missing
    // -----------------------------------------------------------
    async function waitForPoshmarkSpecifics(timeoutMs = 8000){
        console.log("[Poshmark] Waiting for required-specifics-container…");
        const start = Date.now();

        while (Date.now() - start < timeoutMs){
            const cont = document.querySelector('[data-testid="required-specifics-container"]');
            if (cont && cont.offsetParent !== null){
                return cont;
            }
            await sleep(250);
        }

        console.warn("[Poshmark] Timeout waiting for specifics container.");
        return null;
    }

    async function poshmarkInjectRequiredSpecifics(){
        console.log('[Vendoo][Poshmark] Injecting REQUIRED specifics (Size="NA")…');

        const cont = await waitForPoshmarkSpecifics(10000);
        if (!cont){
            console.warn("[Poshmark] Specifics container never appeared.");
            return;
        }

        // This is the key: use the label's "for" to get the exact base field id.
        // In your HTML, label for="..._size" and the REAL required textbox is:
        // input[type="text"][name="..._size"] (NOT the "..._size_scale" combobox input). :contentReference[oaicite:2]{index=2}
        const sizeLabel = cont.querySelector('label[for*="listings.poshmark.categorySpecifics"][for$="_size"]');

        if (!sizeLabel){
            console.warn("[Poshmark] Size label not found (maybe category doesn't require Size).");
            return;
        }

        const fieldFor = sizeLabel.getAttribute("for"); // e.g. listings.poshmark.categorySpecifics.<hash>_size
        if (!fieldFor){
            console.warn("[Poshmark] Size label had no 'for' attribute.");
            return;
