// ==UserScript==
// @name         MadRad → Temporary Vendoo Autofill Backlist items
// @namespace    mrad.vendoo
// @version      1.0.0
// @description  Fill Vendoo once; native setter; ACK/guard; Condition stable; Category with multi-trigger & multi-surface detection
// @match        https://web.vendoo.co/app/item/*
// @run-at       document-idle
//@grant GM_xmlhttpRequest
//@connect img.resellpros.com
// ==/UserScript==

(function () {
  'use strict';

  console.log("[Vendoo userscript] Loaded userscript 1.6.5 with enhanced logging");

  const TOKEN = 'MRAD_VENDOO_V1';
  const TYPE_DELAY = [80, 140];
  const BETWEEN_FIELD = [280, 520];
  const COOLDOWN_MS = 30000;

  let BUSY = false;
  let DONE_UNTIL = 0;
  const ELS = {};

  const sleep = (ms) => new Promise(r => setTimeout(r, ms));
  const rand  = (a,b) => Math.floor(Math.random()*(b-a+1))+a;
  // -------------------------------------------------------------
  // TEMP Backlist Controls
  // -------------------------------------------------------------
  let DRY_RUN = false;
  let TARGETS = ["shopify","whatnot","facebook","etsy","poshmark","mercari","ebay","depop"]; // edit as needed

  function isVendooItemPage(){
    return /^\/app\/item\/[A-Za-z0-9_-]+$/.test(location.pathname);
  }

  function isVendooFormVisible(){
    // loose check: big title "Vendoo Form"
    const h = Array.from(document.querySelectorAll("h1,h2")).find(x =>
      (x.textContent || "").trim().toLowerCase() === "vendoo form"
    );
    return !!h;
  }

  function mountBacklistPanel(){
    if (document.getElementById("mrad-backlist-panel")) return;

    const panel = document.createElement("div");
    panel.id = "mrad-backlist-panel";
    panel.style.position = "fixed";
    panel.style.right = "14px";
    panel.style.bottom = "14px";
    panel.style.zIndex = "999999";
    panel.style.background = "rgba(20,20,20,0.92)";
    panel.style.color = "#fff";
    panel.style.padding = "10px";
    panel.style.borderRadius = "10px";
    panel.style.fontFamily = "system-ui, -apple-system, Segoe UI, Roboto, Arial";
    panel.style.boxShadow = "0 8px 28px rgba(0,0,0,0.28)";
    panel.style.width = "230px";

    panel.innerHTML = `
      <div style="font-weight:700; margin-bottom:8px;">MRAD Backlist</div>

      <button id="mrad-start" style="
        width:100%; padding:10px; border-radius:10px;
        border:0; cursor:pointer; font-weight:700;
      ">Start Backlist</button>

      <label style="display:flex; gap:8px; align-items:center; margin-top:10px; font-size:13px;">
        <input id="mrad-dryrun" type="checkbox" />
        Dry run (no List clicks)
      </label>

      <button id="mrad-targets" style="
        width:100%; margin-top:10px; padding:8px; border-radius:10px;
        border:1px solid rgba(255,255,255,0.18); background:transparent; color:#fff;
        cursor:pointer; font-weight:600;
      ">Edit targets</button>

      <div id="mrad-status" style="margin-top:10px; font-size:12px; opacity:0.9;">Idle</div>
    `;

    document.body.appendChild(panel);

    const statusEl = panel.querySelector("#mrad-status");

    panel.querySelector("#mrad-dryrun").addEventListener("change", (e) => {
      DRY_RUN = !!e.target.checked;
      statusEl.textContent = `Dry run: ${DRY_RUN ? "ON" : "OFF"}`;
    });

    panel.querySelector("#mrad-targets").addEventListener("click", () => {
      const cur = TARGETS.join(",");
      const next = prompt("Comma-separated targets (example: ebay,etsy,shopify)", cur);
      if (next == null) return;
      TARGETS = next.split(",").map(s => s.trim().toLowerCase()).filter(Boolean);
      statusEl.textContent = `Targets: ${TARGETS.join(", ") || "(none)"}`;
    });

    panel.querySelector("#mrad-start").addEventListener("click", async () => {
      statusEl.textContent = "Starting…";
      const result = await runBacklistNow({ dryRun: DRY_RUN, targets: TARGETS });
      statusEl.textContent = result ? "Done ✅ (see console)" : "Failed ❌ (see console)";
    });

    // set initial UI state
    statusEl.textContent = `Targets: ${TARGETS.join(", ")}`;
  }

  async function runBacklistNow({ dryRun, targets }){
    if (!isVendooItemPage()){
      console.warn("[Vendoo userscript] Not on /app/item/* page, refusing to run.");
      return null;
    }

    const now = Date.now();
    if (BUSY){
      console.warn("[Vendoo userscript] Already running; BUSY=true");
      return null;
    }
    if (now < DONE_UNTIL){
      console.warn("[Vendoo userscript] Cooldown active until:", new Date(DONE_UNTIL).toISOString());
      return null;
    }

    BUSY = true;
    try{
      // Wait for the marketplace tiles to exist & stabilize before we start clicking
      await waitForPostSaveStabilization(20000);

      // payload-free run (temporary)
      const p = {};
      const out = await fillVendoo(p, { dryRun: !!dryRun, targets: Array.isArray(targets) ? targets : [] });

      console.log("[Vendoo userscript] Backlist run complete:", out);
      window.__MRAD_BACKLIST_LAST__ = out;
      DONE_UNTIL = Date.now() + COOLDOWN_MS;
      return out;
    } finally {
      BUSY = false;
    }
  }

  async function initBacklistUI(){
    // We only mount UI when the Vendoo Form is visible.
    // Vendoo can re-render; we retry a few times.
    for (let i = 0; i < 40; i++){
      if (isVendooFormVisible()){
        mountBacklistPanel();
        return;
      }
      await sleep(500);
    }
    console.warn("[Vendoo userscript] Vendoo Form not detected; panel not mounted.");
  }



  /* --------- small helpers --------- */
  function visible(node){
    const ok = node && getComputedStyle(node).display !== 'none' && getComputedStyle(node).visibility !== 'hidden';
    if (!ok) console.debug("[Vendoo userscript] not visible:", node);
    return ok;
  }

  async function safeClick(el){
    console.log("[Vendoo userscript] safeClick:", el);
    if (!el) return;
    el.scrollIntoView({behavior:'smooth', block:'center'});
    await sleep(rand(110, 220));
    el.click();
    await sleep(rand(180, 360));
  }

  async function blurCommit(el){
    console.log("[Vendoo userscript] blurCommit:", el);
    el?.blur?.();
    await sleep(rand(160, 300));
  }

  const inputSetter    = Object.getOwnPropertyDescriptor(HTMLInputElement.prototype, 'value')?.set;
  const textareaSetter = Object.getOwnPropertyDescriptor(HTMLTextAreaElement.prototype, 'value')?.set;

  function setNativeValue(el, value){
    console.log("[Vendoo userscript] setNativeValue:", {el, value});
    const setter = el instanceof HTMLTextAreaElement ? textareaSetter : inputSetter;
    if (setter) setter.call(el, value); else el.value = value;
    el.dispatchEvent(new InputEvent('input', {bubbles:true}));
  }

  async function typeHuman(el, text){
    console.log("[Vendoo userscript] typeHuman:", {el, text});
    if (!el) return;
    el.scrollIntoView({behavior:'smooth', block:'center'});
    await sleep(rand(110, 220));
    el.focus();
    const target = String(text ?? '');
    let buf = '';
    for (const ch of target){
      buf += ch;
      setNativeValue(el, buf);
      await sleep(rand(...TYPE_DELAY));
    }
    el.dispatchEvent(new Event('change', {bubbles:true}));
    await blurCommit(el);
    await sleep(rand(...BETWEEN_FIELD));
  }


    // -------------------------------------------------------------
    // Wait for Vendoo to finish image processing before SAVE
    // Vendoo shows loader elements while images are processing.
    // -------------------------------------------------------------
    async function waitForVendooImagesToFinish(timeoutMs = 60000){
        console.log("[Vendoo userscript] Waiting for images to finish processing…");

        const start = Date.now();
        let lastCount = null;

        while (Date.now() - start < timeoutMs){
            // Vendoo uses many loader formats; cover all known variants
            const loaders = document.querySelectorAll(
                '.loading-indicator, .spinner, [data-testid*="loading"], [class*="Loading"], [class*="loading"], [aria-busy="true"]'
            );

            const count = loaders.length;
            if (count !== lastCount){
                console.log("[Vendoo userscript] Image loader count:", count);
                lastCount = count;
            }

            // No loaders = images processed
            if (count === 0){
                console.log("[Vendoo userscript] All images finished processing.");
                return true;
            }

            await sleep(500);
        }

        console.warn("[Vendoo userscript] Timeout waiting for images to finish.");
        return false;
    }

    async function waitForListingStatusComplete(timeoutMs = 20000){
        console.log("[Vendoo] Waiting for Listing Status = COMPLETE…");

        const start = Date.now();
        while (Date.now() - start < timeoutMs){
            const badge = document.querySelector('[data-testid="listing-status-container"] .badges__BadgeStyled-tiu9w6-0');

           if (badge){
               const txt = (badge.textContent || "").trim().toLowerCase();
               console.log("[Vendoo] Listing status badge:", txt);

               // Success conditions
               if (txt.includes("complete") || txt.includes("in progress")){
                   console.log("[Vendoo] Listing status is acceptable:", txt);
                   return true;
               }
           }
        }

        console.warn("[Vendoo] Timeout waiting for listing status COMPLETE.");
        return false;
    }

    //--------------------------------------------------------------
// Wait for Vendoo to fully re-render the page after Save.
// We DO NOT rely on Listing Status alone.
// We wait until marketplace sidebar tiles are present AND stable.
//--------------------------------------------------------------
async function waitForPostSaveStabilization(timeoutMs = 15000){
    console.log("[Vendoo] Waiting for post-save UI stabilization…");

    const start = Date.now();
    let lastTileCount = 0;

    while (Date.now() - start < timeoutMs){
        const tiles = document.querySelectorAll('[role^="side-control-"], [role^="sidebar-option-"]');

        if (tiles.length >= 3){  // Vendoo always shows at least 3 marketplaces
            if (tiles.length === lastTileCount){
                console.log("[Vendoo] UI stabilized with", tiles.length, "marketplace tiles");
                return true;
            }
            lastTileCount = tiles.length;
        }

        await sleep(300);
    }

    console.warn("[Vendoo] Timeout waiting for UI stabilization.");
    return false;
}

      // --- Save & capture Vendoo Item ID from URL (final) ---
    async function clickSaveAndWaitForId(timeoutMs = 120000) {
        // Vendoo's primary Save button (confirmed via data-testid)
        // Fallbacks included for safety across minor DOM changes.
        // Ref: HTML shows <button data-testid="save-item-button" role="save">Save</button>
        const findBtn = () =>
        document.querySelector(
            '[data-testid="save-item-button"],' +                 // primary (confirmed)
            'button[data-testid="save-btn"],' +                  // possible alt
            'button[type="submit"][class*="save"],' +            // generic fallback
            '[aria-label="Save"]'                                // ARIA fallback
        );

        // Utility: strong matcher for post-save item URL
        // Require a long token so "/app/item/new" cannot match.
        const matchItem = () => {
            const m = location.pathname.match(/\/app\/item\/([A-Za-z0-9_-]{12,})$/);
            // explicitly reject "new" just in case
            return (m && m[1] && m[1] !== 'new') ? m[1] : null;
        };

        // 1) Click Save (if/when present)
        const start = Date.now();
        let btn = findBtn();
        while (!btn && Date.now() - start < 5000) { // allow a short render delay
            await sleep(250);
            btn = findBtn();
        }
        if (btn && !btn.disabled) {
            await safeClick(btn);                    // gentle scroll + click + small waits
        }

        // 2) Poll for the new canonical URL with real Item ID
        // We also watch the "Not Saved" badge to disappear as a secondary signal,
        // but the URL match is authoritative.
        let id = null, url = null;
        const metaBadgeGone = () => {
            const badge = document.querySelector('[data-testid="listing-status-container"] .badges__BadgeStyled-tiu9w6-0');
            const txt = (badge && badge.textContent || '').trim().toLowerCase();
            return !!badge && txt !== 'not saved' && txt !== '';
        };

  while (Date.now() - start < timeoutMs) {
    const got = matchItem();
    if (got) {
      id  = got;
      url = location.origin + '/app/item/' + id; // canonicalize; ignore transient qs/hash
      break;
    }
    // If status badge flips away from "Not Saved", give the router a couple beats
    if (metaBadgeGone()) await sleep(600);
    await sleep(400);
  }

  return { id, url };
}

  async function overwriteInput(el, text){
    console.log("[Vendoo userscript] overwriteInput:", {el, text});
    if (!el) return;
    el.scrollIntoView({behavior:'smooth', block:'center'});
    await sleep(rand(110, 220));
    el.focus();
    try { el.select?.(); el.setSelectionRange?.(0, (el.value||'').length); } catch(_){}
    setNativeValue(el, String(text ?? ''));
    el.dispatchEvent(new Event('change', {bubbles:true}));
    await blurCommit(el);
    await sleep(rand(...BETWEEN_FIELD));
  }

  async function fillEditable(el, text){
    console.log("[Vendoo userscript] fillEditable:", {el, text});
    if (!el) return;
    el.scrollIntoView({behavior:'smooth', block:'center'});
    await sleep(rand(110, 220));
    el.focus();
    el.textContent = '';
    el.dispatchEvent(new InputEvent('input', {bubbles:true, inputType:'deleteContentBackward'}));
    el.textContent = String(text ?? '');
    el.dispatchEvent(new InputEvent('input', {bubbles:true, inputType:'insertFromPaste'}));
    el.dispatchEvent(new Event('change', {bubbles:true}));
    await blurCommit(el);
    await sleep(rand(...BETWEEN_FIELD));
  }

  /* --------- finders --------- */
  function $xOne(xp, root=document){
    const node = document.evaluate(xp, root, null, XPathResult.FIRST_ORDERED_NODE_TYPE, null).singleNodeValue || null;
    console.debug("[Vendoo userscript] $xOne:", {xp, root, node});
    return node;
  }

  function byLabelInput(label){
    return $xOne(`//label[contains(normalize-space(.),"${label}")]/following::*[self::input or self::textarea][1]`);
  }

  function byLabelEditable(label){
    return $xOne(`//label[contains(normalize-space(.),"${label}")]/following::*[@contenteditable="true"][1]`);
  }

  function byPlaceholder(ph){
    const node = document.querySelector(`input[placeholder="${ph}"], textarea[placeholder="${ph}"]`);
    console.debug("[Vendoo userscript] byPlaceholder:", {ph, node});
    return node;
  }





    /* --------- marketplace helpers (status, tile, list, capture URL) --------- */

function getMarketplaceStatus(marketplace){
    // Sidebar example from your uploaded HTML:
    // <div role="sidebar-option-shopify">
    //    <button data-testid="dropdown-menu-listed">Listed</button>
    // OR <button data-testid="dropdown-menu-notListed">Not Listed</button>
    // </div>

    const root = document.querySelector(`[role="sidebar-option-${marketplace}"]`);

    if (!root){
        console.warn(`[Vendoo] getMarketplaceStatus: sidebar container NOT FOUND for ${marketplace}`);
        return "unknown";
    }

    // Direct, authoritative selectors:
    const listedBtn    = root.querySelector('button[data-testid="dropdown-menu-listed"]');
    const notListedBtn = root.querySelector('button[data-testid="dropdown-menu-notListed"]');

    if (listedBtn){
        console.log(`[Vendoo] ${marketplace} STATUS = listed (via data-testid)`);
        return "listed";
    }

    if (notListedBtn){
        console.log(`[Vendoo] ${marketplace} STATUS = notListed (via data-testid)`);
        return "notListed";
    }

    // Fallback to text-content search (in case Vendoo changes data-testid)
    const txt = (root.textContent || "").trim().toLowerCase();

    if (txt.includes("listed") && !txt.includes("not listed")){
        console.log(`[Vendoo] ${marketplace} STATUS = listed (via fallback text)`);
        return "listed";
    }

    if (txt.includes("not listed") || txt.includes("not saved")){
        console.log(`[Vendoo] ${marketplace} STATUS = notListed (via fallback text)`);
        return "notListed";
    }

    console.warn(`[Vendoo] ${marketplace} STATUS = unknown (no match found)`, { txt });
    return "unknown";
}

async function openMarketplaceTile(marketplace){
    const tile =
        document.querySelector(`button[role="side-control-${marketplace}"]`) ||
        document.querySelector(`#${marketplace}`);

    console.log("[Vendoo userscript] openMarketplaceTile:", { marketplace, tile });

    if (!tile){
        console.warn(`[Vendoo userscript] Tile not found for marketplace ${marketplace}`);
        return false;
    }

    await safeClick(tile);
    await sleep(rand(500, 900));
    return true;
}


async function waitForMarketplaceForm(detectorFn, marketplace, timeoutMs = 8000){
    console.log("[Vendoo userscript] waitForMarketplaceForm start:", { marketplace, timeoutMs });

    const t0 = Date.now();
    let node = null;

    while (Date.now() - t0 < timeoutMs){
        try{
            node = detectorFn();
        } catch(e){
            console.warn("[Vendoo userscript] waitForMarketplaceForm detector error:", { marketplace, error: e });
        }

        if (node){
            console.log("[Vendoo userscript] waitForMarketplaceForm: form detected", { marketplace, node });
            return node;
        }

        await sleep(250);
    }

    console.warn("[Vendoo userscript] waitForMarketplaceForm: timed out", { marketplace, timeoutMs });
    return null;
}

async function clickShopifyListButton() {
    // Vendoo Shopify buttons are just <button> with visible text
    const btn = Array.from(document.querySelectorAll("button"))
        .find(b => (b.textContent || "").trim().toLowerCase().includes("list on shopify"));

    console.log("[Vendoo userscript] Shopify list button found:", btn);

    if (!btn) return false;

    await safeClick(btn);
    return true;
}


async function clickListButton(marketplace, labels){
    // labels: array of lowercase substrings, e.g. ["list on shopify"]
    const allButtons = Array.from(document.querySelectorAll('button, div[role="button"]'));
    const btn = allButtons.find(b => {
        const txt = (b.textContent || "").trim().toLowerCase();
        return labels.some(label => txt.includes(label));
    });

    console.log("[Vendoo userscript] clickListButton candidate:", { marketplace, btn, labels });

    if (!btn){
        console.warn("[Vendoo userscript] clickListButton: no matching button", { marketplace, labels });
        return false;
    }

    await safeClick(btn);
    return true;
}

async function waitForListingUrl(listingUrlSelector, marketplace, timeoutMs = 60000){
    console.log("[Vendoo userscript] waitForListingUrl start:", {
        marketplace,
        listingUrlSelector,
        timeoutMs
    });

    const start = Date.now();
    let lastInputVal = null;
    let lastAnchorHref = null;

    while (Date.now() - start < timeoutMs){
        const input = listingUrlSelector
            ? document.querySelector(listingUrlSelector)
            : null;

        const val = input && input.value ? input.value.trim() : null;

        const viewAnchor =
            document.querySelector('#listed-status-container a[role="view-listing-btn"]') ||
            document.querySelector('#listed-status-container a[href^="http"]');

        const href = viewAnchor && viewAnchor.href ? viewAnchor.href : null;

        lastInputVal = val;
        lastAnchorHref = href;

        if (val || href){
            const listing_url = val || href;
            console.log("[Vendoo userscript] waitForListingUrl: got listing URL", {
                marketplace,
                listing_url,
                from: val ? "input" : "anchor",
                input,
                viewAnchor
            });
            return {
                listing_url,
                from: val ? "input" : "anchor"
            };
        }

        await sleep(500);
    }

    console.warn("[Vendoo userscript] waitForListingUrl: timeout without URL", {
        marketplace,
        lastInputVal,
        lastAnchorHref
    });

    return {
        listing_url: null,
        from: "timeout"
    };
}

