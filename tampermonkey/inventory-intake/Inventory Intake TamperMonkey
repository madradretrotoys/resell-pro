  function findCategorySurface(){
  console.log("[Vendoo userscript] findCategorySurface() robust…");

  // Most reliable anchor: Vendoo's category search field
  const search = document.querySelector('input[data-testid="category-search-field"]');
  if (search && search.offsetParent !== null){
    // Walk upward until we find a container that also contains options
    let node = search.parentElement;
    for (let i = 0; i < 12 && node; i++){
      const hasOptions = !!node.querySelector('div[data-testid="category-option-dropdown"][role="option"]');
      const hasCancel  = !!node.querySelector('button[data-testid="cancel-category-selection-button"]');
      if (hasOptions || hasCancel){
        console.log("[Vendoo userscript] surface FOUND via search ancestor:", node);
        return node;
      }
      node = node.parentElement;
    }

    // Fallback: return closest visible ancestor
    console.log("[Vendoo userscript] surface fallback (closest ancestor):", search.parentElement);
    return search.parentElement;
  }

  console.log("[Vendoo userscript] surface NOT FOUND (no category-search-field visible)");
  return null;
}

  function findCategorySearch(surf){
      const el =
            surf?.querySelector('input[data-testid="category-search-field"]') ||
            surf?.querySelector('input[placeholder*="Search"]');

      console.log("[Vendoo userscript] findCategorySearch (LEGACY FIX):", el);
      return el;
  }

  function findCategoryOptions(surf){
      const opts = Array.from(
          surf?.querySelectorAll('div[data-testid="category-option-dropdown"][role="option"]') || []
      ).filter(el => el.offsetParent !== null);

      console.log("[Vendoo userscript] findCategoryOptions (LEGACY FIX):", opts);
      return opts;
  }

  function bestOptionByText(options, want){
    const t = String(want||'').toLowerCase().trim();
    console.log("[Vendoo userscript] bestOptionByText target:", t);
    let best=null, score=-1;
    for (const opt of options){
      const txt = String(opt.textContent||'').toLowerCase().trim();
      let s=-1;
      if      (txt === t)        s=3;
      else if (txt.startsWith(t)) s=2;
      else if (txt.includes(t))   s=1;

      console.debug("[Vendoo userscript] option candidate:", {opt, txt, score:s});
      if (s>score){ best=opt; score=s; if (s===3) break; }
    }
    console.log("[Vendoo userscript] bestOptionByText final:", best);
    return best;
  }

  async function openCategorySurface(maxTries=4){
    console.log("[Vendoo userscript] openCategorySurface()");
    for (let i=0;i<maxTries;i++){
      let surf = findCategorySurface();
      if (surf) return surf;

      const trigger = ELS.categoryTrigger || (ELS.categoryTrigger = pickCategoryTrigger());
      console.log("[Vendoo userscript] Category trigger:", trigger);
      if (!trigger) { await sleep(200); continue; }

      await safeClick(trigger);

      const t0 = Date.now();
      while (Date.now()-t0 < 1500){
        surf = findCategorySurface();
        if (surf) return surf;
        await sleep(150);
      }
      await sleep(220);
    }
    console.warn("[Vendoo userscript] openCategorySurface: surface still not found");
    return findCategorySurface();
  }

