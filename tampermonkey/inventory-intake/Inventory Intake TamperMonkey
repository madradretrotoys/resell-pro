async function waitForPostSaveStabilization(timeoutMs = 15000){
    console.log("[Vendoo] Waiting for post-save UI stabilization…");

    const start = Date.now();
    let lastTileCount = 0;

    while (Date.now() - start < timeoutMs){
        const tiles = document.querySelectorAll('[role^="side-control-"], [role^="sidebar-option-"]');

        if (tiles.length >= 3){  // Vendoo always shows at least 3 marketplaces
            if (tiles.length === lastTileCount){
                console.log("[Vendoo] UI stabilized with", tiles.length, "marketplace tiles");
                return true;
            }
            lastTileCount = tiles.length;
        }

        await sleep(300);
    }

    console.warn("[Vendoo] Timeout waiting for UI stabilization.");
    return false;
}

      // --- Save & capture Vendoo Item ID from URL (final) ---
    async function clickSaveAndWaitForId(timeoutMs = 120000) {
        // Vendoo's primary Save button (confirmed via data-testid)
        // Fallbacks included for safety across minor DOM changes.
        // Ref: HTML shows <button data-testid="save-item-button" role="save">Save</button>
        const findBtn = () =>
        document.querySelector(
            '[data-testid="save-item-button"],' +                 // primary (confirmed)
            'button[data-testid="save-btn"],' +                  // possible alt
            'button[type="submit"][class*="save"],' +            // generic fallback
            '[aria-label="Save"]'                                // ARIA fallback
        );

        // Utility: strong matcher for post-save item URL
        // Require a long token so "/app/item/new" cannot match.
        const matchItem = () => {
            const m = location.pathname.match(/\/app\/item\/([A-Za-z0-9_-]{12,})$/);
            // explicitly reject "new" just in case
            return (m && m[1] && m[1] !== 'new') ? m[1] : null;
        };

        // 1) Click Save (if/when present)
        const start = Date.now();
        let btn = findBtn();
        while (!btn && Date.now() - start < 5000) { // allow a short render delay
            await sleep(250);
            btn = findBtn();
        }
        if (btn && !btn.disabled) {
            await safeClick(btn);                    // gentle scroll + click + small waits
        }

        // 2) Poll for the new canonical URL with real Item ID
        // We also watch the "Not Saved" badge to disappear as a secondary signal,
        // but the URL match is authoritative.
        let id = null, url = null;
        const metaBadgeGone = () => {
            const badge = document.querySelector('[data-testid="listing-status-container"] .badges__BadgeStyled-tiu9w6-0');
            const txt = (badge && badge.textContent || '').trim().toLowerCase();
            return !!badge && txt !== 'not saved' && txt !== '';
        };

  while (Date.now() - start < timeoutMs) {
    const got = matchItem();
    if (got) {
      id  = got;
      url = location.origin + '/app/item/' + id; // canonicalize; ignore transient qs/hash
      break;
    }
    // If status badge flips away from "Not Saved", give the router a couple beats
    if (metaBadgeGone()) await sleep(600);
    await sleep(400);
  }

  return { id, url };
}

  async function overwriteInput(el, text){
    console.log("[Vendoo userscript] overwriteInput:", {el, text});
    if (!el) return;
    el.scrollIntoView({behavior:'smooth', block:'center'});
    await sleep(rand(110, 220));
    el.focus();
    try { el.select?.(); el.setSelectionRange?.(0, (el.value||'').length); } catch(_){}
    setNativeValue(el, String(text ?? ''));
    el.dispatchEvent(new Event('change', {bubbles:true}));
    await blurCommit(el);
    await sleep(rand(...BETWEEN_FIELD));
  }

  async function fillEditable(el, text){
    console.log("[Vendoo userscript] fillEditable:", {el, text});
    if (!el) return;
    el.scrollIntoView({behavior:'smooth', block:'center'});
    await sleep(rand(110, 220));
    el.focus();
    el.textContent = '';
    el.dispatchEvent(new InputEvent('input', {bubbles:true, inputType:'deleteContentBackward'}));
    el.textContent = String(text ?? '');
    el.dispatchEvent(new InputEvent('input', {bubbles:true, inputType:'insertFromPaste'}));
    el.dispatchEvent(new Event('change', {bubbles:true}));
    await blurCommit(el);
    await sleep(rand(...BETWEEN_FIELD));
  }

