  /* ------------ CATEGORY LOGGING HEAVY -------------- */
  function pickCategoryTrigger(){
      console.log("[Vendoo userscript] pickCategoryTrigger() LEGACY FIX…");

      // Exact Vendoo category trigger
      const btn = document.querySelector('button[role="category-input"]');

      // Fallback: button with id categoryV2
