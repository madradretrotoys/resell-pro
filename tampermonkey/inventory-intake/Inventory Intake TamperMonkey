    // Selects the FIRST brand option
    // -----------------------------------------------------------

    async function depopInjectRequiredSpecifics(vm){
        console.log("[Vendoo][Depop] Injecting REQUIRED specifics (Brand)…");

        // 1) Locate the Depop brand field container
        const root =
              document.querySelector('[data-testid="listings.depop.overrides.brand-multi-selector-container"]') ||
              document.querySelector('#listings\\.depop\\.overrides\\.brand') ||
              document.querySelector('input[name="listings.depop.overrides.brand"]');

        if (!root){
            console.warn("[Depop] Brand container NOT FOUND.");
            return false;
        }

        // The actual Downshift <input>
        const input = (root.tagName === "INPUT" ? root : root.querySelector("input"));
        if (!input){
            console.warn("[Depop] Brand input NOT FOUND.");
            return false;
        }

        // Hidden/native field often exists; if present, it’s the best “did it stick?” signal
        const hidden =
              document.querySelector('input[name="listings.depop.overrides.brand"]') ||
              (root.tagName === "INPUT" ? root : root.querySelector('input[name="listings.depop.overrides.brand"]'));

        function pickVisibleListbox(menuId){
            // Prefer aria-controls
            if (menuId){
                const el = document.getElementById(menuId);
                if (el && el.offsetParent !== null) return el;
            }

            // Fallback: pick the LAST visible listbox (most recently opened)
            const boxes = Array.from(document.querySelectorAll('[role="listbox"]'))
            .filter(el => el.offsetParent !== null);

            return boxes.length ? boxes[boxes.length - 1] : null;
        }

        function fireMouseSequence(el){
            // React/Downshift sometimes needs mousedown/mouseup to commit selection
            try{
                el.dispatchEvent(new MouseEvent("mousedown", { bubbles:true, cancelable:true, view:window }));
                el.dispatchEvent(new MouseEvent("mouseup",   { bubbles:true, cancelable:true, view:window }));
            } catch(_){}
            el.click();
        }

        async function didBrandStick(expectedText){
            const start = Date.now();
            while (Date.now() - start < 1200){
                const hv = (hidden && hidden.value ? String(hidden.value) : "").trim();
                const iv = (input && input.value ? String(input.value) : "").trim();

                // Common success cases: hidden value or input value becomes non-empty and not just our search char
                if (hv && hv.toLowerCase() !== "a") return true;
                if (iv && iv.toLowerCase() !== "a") return true;

                // Chip-based UIs: selected value often appears as text inside the container
                const containerText = String(
                    (root.tagName === "INPUT" ? root.parentElement : root).textContent || ""
                ).toLowerCase();

                if (expectedText && containerText.includes(String(expectedText).toLowerCase())){
                    return true;
                }

                await sleep(120);
            }
            return false;
        }

        // Retry loop (timing flake fix)
        const MAX_TRIES = 4;

        for (let attempt = 1; attempt <= MAX_TRIES; attempt++){
            console.log(`[Vendoo][Depop] Brand select attempt ${attempt}/${MAX_TRIES}`);

            // Step 1: focus/open
            input.scrollIntoView({ behavior:"smooth", block:"center" });
            await sleep(rand(120, 220));
            input.focus();
            await sleep(rand(120, 220));

            // Clear any prior partial text
            setNativeValue(input, "");
            await sleep(rand(80, 140));

            // Step 2: Type a char to trigger Downshift search
            setNativeValue(input, "a");
            input.dispatchEvent(new InputEvent("input", { bubbles:true }));
            await sleep(rand(140, 240));

            // Step 3: ArrowDown to force menu open
            input.dispatchEvent(new KeyboardEvent("keydown", {
                key: "ArrowDown",
                code: "ArrowDown",
                keyCode: 40,
                which: 40,
                bubbles: true
            }));
            await sleep(rand(180, 320));

            // Step 4: find the Downshift menu (robust)
            const menuId = input.getAttribute("aria-controls");
            let listbox = null;

            for (let i = 0; i < 12; i++){
                listbox = pickVisibleListbox(menuId);
                if (listbox) break;
                await sleep(120);
            }

            if (!listbox){
                console.warn("[Depop] listbox NOT FOUND (attempt failed).");
                await sleep(rand(180, 300));
                continue;
            }

            // Step 5: find visible options
            const options = Array.from(listbox.querySelectorAll('[role="option"]'))
            .filter(el => el.offsetParent !== null);

            if (!options.length){
                console.warn("[Depop] No visible brand options (attempt failed).");
                await sleep(rand(180, 300));
                continue;
            }

            const first = options[0];
            const firstText = (first.textContent || "").trim();

            console.log("[Depop] Selecting FIRST brand option:", firstText);

            // Use a stronger “commit” click sequence
            first.scrollIntoView({ behavior:"smooth", block:"nearest" });
            await sleep(rand(80, 140));
            fireMouseSequence(first);

            await sleep(rand(140, 240));
            await blurCommit(input);

            // Verify it actually stuck
            const ok = await didBrandStick(firstText);
            if (ok){
                console.log("[Vendoo][Depop] Brand injection COMPLETE (verified).");
                return true;
            }

            console.warn("[Vendoo][Depop] Brand click did NOT stick; retrying…");
            await sleep(rand(220, 420));
        }

        console.error("[Vendoo][Depop] Brand injection FAILED after retries.");
        return false;
    }


