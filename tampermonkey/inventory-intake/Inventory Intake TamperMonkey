  /* --------- bridge (ACK + guard) --------- */
  window.addEventListener('message', async (ev) => {
    console.log("[Vendoo userscript] message event:", ev.data);

    try{
      const d = ev.data || {};
      if (d.type !== 'mrad_vendoo_fill'){
        console.debug("[Vendoo userscript] message ignored: wrong type");
        return;
      }
      const p = d.payload || {};
      if (p.__token !== TOKEN){
        console.warn("[Vendoo userscript] message ignored: wrong token", p.__token);
        return;
      }

      try {
        window.opener?.postMessage({ type: 'mrad_vendoo_ack' }, '*');
        console.log("[Vendoo userscript] Sent ACK to opener");
      } catch(e){
        console.warn("[Vendoo userscript] Could NOT send ACK:", e);
      }

      if (BUSY || Date.now() < DONE_UNTIL){
        console.debug("[Vendoo userscript] Ignored duplicate payload (busy or cooldown)", {
          BUSY,
          NOW: Date.now(),
          DONE_UNTIL
        });
        return;
      }

      BUSY = true;
      console.log("[Vendoo userscript] BEGIN fillVendoo() for payload", p);

      await sleep(rand(700, 1200));

      const result = await fillVendoo(p);

      DONE_UNTIL = Date.now() + COOLDOWN_MS;
      console.log("[Vendoo userscript] Fill complete; cooldown started", {
        DONE_UNTIL,
        result
      });

      // Forward final result back to opener so Resell Pro can persist:
      try {
        if (window.opener){
          window.opener.postMessage({
            type: 'mrad_vendoo_result',
            payload: result
          }, '*');
          console.log("[Vendoo userscript] Posted mrad_vendoo_result payload to opener:", result);
        } else {
          console.warn("[Vendoo userscript] No window.opener present; cannot send mrad_vendoo_result");
        }
      } catch (postErr){
        console.error("[Vendoo userscript] Error posting mrad_vendoo_result to opener:", postErr);
      }

    } catch (e){
      console.error('[Vendoo userscript] Error during message handler:', e);
    } finally {
      BUSY = false;
      console.log("[Vendoo userscript] BUSY set to false");
    }
  }, false);

