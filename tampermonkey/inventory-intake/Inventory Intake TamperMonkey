  function fireMouseSequence(el){
      // React sometimes needs mousedown/mouseup to commit selection
      try{
          el.dispatchEvent(new MouseEvent("mousedown", { bubbles:true, cancelable:true, view:window }));
          el.dispatchEvent(new MouseEvent("mouseup",   { bubbles:true, cancelable:true, view:window }));
      } catch(_){}
      el.click();
  }

    async function waitForCategoryCommit(label, timeoutMs = 2200){
        const want = String(label || "").trim().toLowerCase();
        const start = Date.now();

        while (Date.now() - start < timeoutMs){
            // Signal A: picker surface closed (search field gone)
            const search = document.querySelector('input[data-testid="category-search-field"]');
            if (!search || search.offsetParent === null){
                console.log("[Vendoo userscript] Category commit detected (surface closed).");
                return true;
            }

            // Signal B: category trigger text updated to include leaf
            const trig = ELS.categoryTrigger || pickCategoryTrigger();
            const trigTxt = (trig?.textContent || "").trim().toLowerCase();
            if (want && trigTxt.includes(want)){
                console.log("[Vendoo userscript] Category commit detected (trigger text match):", trigTxt);
                return true;
            }

            await sleep(120);
        }

        console.warn("[Vendoo userscript] Category commit NOT detected (timeout).");
        return false;
    }

    async function clickOptionByText(surf, label){
        console.log("[Vendoo userscript] clickOptionByText (robust):", label);

        const opts = findCategoryOptions(surf);
        const node = bestOptionByText(opts, label);

        if (!node){
            console.warn("[Vendoo userscript] category option NOT FOUND:", label);
            return false;
        }

        console.log("[Vendoo userscript] clicking category option (robust):", node);

        // Stronger “commit click” than safeClick alone
        node.scrollIntoView({behavior:'smooth', block:'center'});
        await sleep(rand(110, 220));
        fireMouseSequence(node);
        await sleep(rand(180, 360));

        // Verify it actually committed
        const ok = await waitForCategoryCommit(label, 2200);
        if (!ok){
            console.warn("[Vendoo userscript] click did not stick (will allow caller to retry):", label);
            return false;
        }

        return true;
    }

  async function setCategory(pathStr){
    console.log("[Vendoo userscript] setCategory start:", pathStr);
    if (!pathStr) return;

    let surf = await openCategorySurface(4);
    if (!surf){
      console.warn("[Vendoo userscript] setCategory: no surface available");
      return;
    }

    const crumb = breadcrumbsText(surf);
    if (!/action figures & accessories/i.test(crumb)){
      console.log("[Vendoo userscript] stepping into Toys & Hobbies → Action Figures & Accessories");
      await clickOptionByText(surf, 'Toys & Hobbies');
      await sleep(rand(140,280));
      surf = findCategorySurface() || surf;

      await clickOptionByText(surf, 'Action Figures & Accessories');
      await sleep(rand(140,280));
      surf = findCategorySurface() || surf;
    }

    const parts = String(pathStr).split('>').map(s=>s.trim()).filter(Boolean);
    const leaf  = parts[parts.length-1];
    console.log("[Vendoo userscript] Category parts:", parts);

    const search = findCategorySearch(surf);
    if (search){
      console.log("[Vendoo userscript] setCategory using SEARCH:", leaf);
      await overwriteInput(search, leaf);
      await sleep(rand(160,300));
      surf = findCategorySurface() || surf;
      await clickOptionByText(surf, leaf);
      await blurCommit(document.activeElement);
      return;
    }

    console.log("[Vendoo userscript] setCategory using fallback click-through");
    for (const part of parts){
      surf = findCategorySurface() || surf;
      await clickOptionByText(surf, part);
      await sleep(rand(140,280));
    }
    await blurCommit(document.activeElement);
  }

