/* --------- image uploader --------- */

function xhrBlob(url) {
  return new Promise((resolve) => {
    try {
      GM_xmlhttpRequest({
        method: "GET",
        url,
        responseType: "blob",
        onload: res => resolve(res.response || null),
        onerror: () => resolve(null),
        ontimeout: () => resolve(null),
      });
    } catch (e) {
      resolve(null);
    }
  });
}
async function uploadVendooImages(images){
    console.log("[Vendoo userscript] uploadVendooImages:", images);

    if (!images || !Array.isArray(images) || images.length === 0){
        console.warn("[Vendoo userscript] No images in payload.");
        return;
    }

    const dropZone = document.querySelector('[role="drop-zone"]');
    if (!dropZone){
        console.error("[Vendoo userscript] Drop zone not found.");
        return;
    }

    const dt = new DataTransfer();

    for (const img of images){
        try {
            const url  = img.cdn_url;
            const type = img.content_type || "image/jpeg";

            console.log("[Vendoo userscript] xhrBlob fetching", url);
            const blob = await xhrBlob(url);

            if (!blob) {
                console.warn("[Vendoo userscript] xhrBlob failed:", url);
                continue;
            }

            const filename =
                  (img.r2_key?.split("/").pop()) ||
                  ("image_" + Math.random().toString(36).slice(2) + ".jpg");

            const file = new File([blob], filename, { type });
            dt.items.add(file);

        } catch (e) {
            console.error("[Vendoo userscript] File creation error:", e);
        }
    }

    console.log("[Vendoo userscript] Dispatching DROP with", dt.items.length, "files");

    const dropEvent = new DragEvent("drop", {
        bubbles: true,
        cancelable: true,
        dataTransfer: dt
    });

    // Vendoo ONLY listens on the drop-zone wrapper, not the hidden input
    dropZone.dispatchEvent(dropEvent);
}



    /* --------- marketplace helpers (status, tile, list, capture URL) --------- */

function getMarketplaceStatus(marketplace){
    // Sidebar example from your uploaded HTML:
    // <div role="sidebar-option-shopify">
    //    <button data-testid="dropdown-menu-listed">Listed</button>
    // OR <button data-testid="dropdown-menu-notListed">Not Listed</button>
    // </div>

    const root = document.querySelector(`[role="sidebar-option-${marketplace}"]`);

    if (!root){
        console.warn(`[Vendoo] getMarketplaceStatus: sidebar container NOT FOUND for ${marketplace}`);
        return "unknown";
    }

    // Direct, authoritative selectors:
    const listedBtn    = root.querySelector('button[data-testid="dropdown-menu-listed"]');
    const notListedBtn = root.querySelector('button[data-testid="dropdown-menu-notListed"]');

    if (listedBtn){
        console.log(`[Vendoo] ${marketplace} STATUS = listed (via data-testid)`);
        return "listed";
    }

    if (notListedBtn){
        console.log(`[Vendoo] ${marketplace} STATUS = notListed (via data-testid)`);
        return "notListed";
    }

    // Fallback to text-content search (in case Vendoo changes data-testid)
    const txt = (root.textContent || "").trim().toLowerCase();

    if (txt.includes("listed") && !txt.includes("not listed")){
        console.log(`[Vendoo] ${marketplace} STATUS = listed (via fallback text)`);
        return "listed";
    }

