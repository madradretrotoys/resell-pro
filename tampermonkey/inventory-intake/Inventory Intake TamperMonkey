async function processMarketplace(cfg, p){
    const {
        marketplace,
        listLabels,
        formDetector,
        listingUrlSelector
    } = cfg || {};

    console.log("[Vendoo userscript] processMarketplace() begin:", cfg);

    if (!marketplace){
        console.warn("[Vendoo userscript] processMarketplace: missing marketplace name");
        return { status: "error", error: "missing_marketplace" };
    }

    const status = getMarketplaceStatus(marketplace);

    if (status === "listed"){
        console.log("[Vendoo userscript] processMarketplace: already listed → skipping", { marketplace });
        return {
            status: "listed",
            action: "skipped_existing_listing"
        };
    }

    if (status !== "notListed"){
        console.warn("[Vendoo userscript] processMarketplace: status is not explicitly notListed, skipping auto-list", {
            marketplace,
            status
        });
        return {
            status,
            action: "skipped_unknown_status"
        };
    }

    console.log("[Vendoo userscript] processMarketplace: proceeding to auto-list", { marketplace });

    // 1) Open the tile
    const opened = await openMarketplaceTile(marketplace);
    if (!opened){
        return {
            status: "error",
            error: "tile_not_found"
        };
    }

    // 2) Wait for the marketplace form
    const formNode = await waitForMarketplaceForm(
        formDetector,
        marketplace,
        cfg.formTimeoutMs || 8000
    );
    if (!formNode){
        return {
            status: "error",
            error: "form_not_loaded"
        };
    }

    console.log("[Vendoo userscript] Marketplace form loaded for:", marketplace);

    // 2A) SPECIAL CASE: shopify required-specifics injection BEFORE listing
    if (marketplace === "shopify"){
        console.log("[Vendoo userscript] Running shopify specific field injector…");

        try {
            await shopifyInjectRequiredSpecifics(p);
        } catch(err){
            console.error("[Vendoo userscript] shopify injector failed:", err);
        }
    }


    // 2B) SPECIAL CASE: eBay required-specifics injection BEFORE listing
    if (marketplace === "ebay"){
        console.log("[Vendoo userscript] Running eBay specific field injector…");

        try {
            await ebayInjectRequiredSpecifics(p);
        } catch(err){
            console.error("[Vendoo userscript] eBay injector failed:", err);
        }
    }

    // 2C) SPECIAL CASE: depop required-specifics injection BEFORE listing
    if (marketplace === "depop"){
        console.log("[Vendoo userscript] Running depop specific field injector…");

        try {
            await depopInjectRequiredSpecifics(p?.vendoo_mapping || {});
        } catch(err){
            console.error("[Vendoo userscript] depop injector failed:", err);
        }
    }

     // 2D) SPECIAL CASE: poshmark required-specifics injection BEFORE listing
    if (marketplace === "poshmark"){
        console.log('[Vendoo userscript] Running poshmark Size="NA" injector…');

        try {
            await poshmarkInjectRequiredSpecifics();
        } catch(err){
            console.error("[Vendoo userscript] poshmark injector failed:", err);
        }
    }

    // 2E) SPECIAL CASE: mercari injection BEFORE listing
    if (marketplace === "mercari"){
        console.log("[Vendoo userscript] Running mercari injector…");

        try {
            await mercariInjectRequiredSpecifics();
        } catch(err){
            console.error("[Vendoo userscript] mercari injector failed:", err);
        }
    }

    // 2F) SPECIAL CASE: facebook condition + description injection BEFORE listing
    if (marketplace === "facebook"){
        console.log('[Vendoo userscript] Running facebook injectors (Condition + Business Info)…');

        try {
            await facebookInjectRequiredSpecifics();
        } catch(err){
            console.error("[Vendoo userscript] facebook condition injector failed:", err);
        }

        try {
            await facebookInjectBusinessInfoIntoDescription();
        } catch(err){
            console.error("[Vendoo userscript] facebook description injector failed:", err);
        }
    }

    // 3) Click the "List on ____" button
    let clicked = false;

    if (marketplace === "shopify") {
        console.log("[Vendoo userscript] Shopify detected → using special listButton handler");
        clicked = await clickShopifyListButton();
    } else {
        clicked = await clickListButton(marketplace, listLabels);
    }
    if (!clicked){
        return {
            status: "error",
            error: "list_button_not_found"
        };
    }

    // 4) Wait for Vendoo to show "Your item is listed" & URL to appear
    const listingMeta = await waitForListingUrl(listingUrlSelector, marketplace);

    const vendoo_marketplace_url = (() => {
        const base = location.origin + location.pathname;
        return `${base}?marketplace=${encodeURIComponent(marketplace)}`;
    })();

    const out = {
        status: listingMeta.listing_url ? "listed" : "pending_or_unknown",
        vendoo_marketplace_url,
        listing_url: listingMeta.listing_url,
        listing_meta: listingMeta
    };

    console.log("[Vendoo userscript] processMarketplace() result:", { marketplace, out });

    return out;
}

